{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "CUDA_VISIBLE_DEVICES": "9",
                "OMP_NUM_THREADS": "32",
                // "MASTER_ADDR": "localhost",
                // "MASTER_PORT": "12345",
                // "CUDA_LAUNCH_BLOCKING":"1",
                // "TORCH_USE_CUDA_DSA": "1",
            },
        },
        {
            "name": "Render re10k 256x256",
            "type": "debugpy",
            "request": "launch",
            "module": "src.main",
            // "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "CUDA_VISIBLE_DEVICES": "8",
            },
            "args": [
                "+experiment=re10k",
                "dataset.test_chunk_interval=100",
                "dataset.roots=[/data0/xxy/data/re10k]",
                "model.encoder.num_scales=2",
                "model.encoder.upsample_factor=2",
                "model.encoder.lowest_feature_resolution=4",
                "model.encoder.monodepth_vit_type=vitl",
                "model.encoder.gaussian_adapter.gaussian_scale_max=0.1",
                "checkpointing.pretrained_model=pretrained/depthsplat-gs-large-re10k-256x256-view2-e0f0f27a.pth",
                "mode=test",
                "dataset/view_sampler=evaluation",
                "dataset.view_sampler.index_path=assets/evaluation_index_re10k_video.json",
                // "dataset.view_sampler.index_path=assets/re10k_ctx_6v_video.json",
                "dataset.view_sampler.num_context_views=2",
                "test.save_video=false",
                "test.compute_scores=true",
                "test.render_chunk_size=10",
                "output_dir=outputs/depthsplat-re10k-256x256-with-score"
            ]
        },
        {
            "name": "Train re10k 256x256",
            "type": "debugpy",
            "request": "launch",
            "module": "src.main",
            // "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "CUDA_VISIBLE_DEVICES": "5",
                "PYTHONPATH": "/data0/xxy/code/Active-FFGS-streaming/src/third_party/video_depth_anything:${env:PYTHONPATH}"
                // "MASTER_ADDR": "localhost",
                // "MASTER_PORT": "12345",
            },
            "args": [
                "+experiment=re10k",
                "dataset.roots=[/data0/xxy/data/re10k]",
                "data_loader.train.batch_size=2",
                "wandb.mode=disabled",
                "model.encoder.name=efficient_encoder",
                // "model.encoder.name=voxelsplat",
                "dataset.test_chunk_interval=10",
                "trainer.max_steps=300000",
                "model.encoder.upsample_factor=4",
                "model.encoder.lowest_feature_resolution=4",
                "model.encoder.gs_cube=false",
                "model.encoder.monodepth_vit_type=vits",
                // "checkpointing.pretrained_monodepth=pretrained/depth_anything_v2_vits.pth",
                // "checkpointing.pretrained_mvdepth=pretrained/gmflow-scale1-things-e9887eda.pth",
                "output_dir=checkpoints/tmp",
                "dataset.image_shape=[252,252]",
                // "train_controller.depth_distillation=false",
                // "train_controller.teacher_depth=vggt",
                // "train_controller.embedding_type=plucker_ray",
                "dataset.near=0.01",
                // "checkpointing.no_strict_load=true",
                // "train_controller.vggt_meta=true",
            ]
        },
        {
            "name": "Train mono re10k",
            "type": "debugpy",
            "request": "launch",
            "module": "src.main",
            // "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "CUDA_VISIBLE_DEVICES": "5",
                "PYTHONPATH": "/data0/xxy/code/Active-FFGS-streaming/src/third_party/video_depth_anything:${env:PYTHONPATH}"
                // "MASTER_ADDR": "localhost",
                // "MASTER_PORT": "12345",
            },
            "args": [
                "+experiment=re10k",
                "model/encoder=mono_model",
                "dataset.roots=[/data0/xxy/data/re10k]",
                "data_loader.train.batch_size=2",
                "wandb.mode=disabled",
                "dataset.test_chunk_interval=10",
                "trainer.max_steps=300000",
                "dataset.min_views=2",
                "dataset.max_views=2",
                "train.video_viz_interval_steps=1000",
                "trainer.max_steps=100000",
                "output_dir=checkpoints/monosplat"
            ]
        },
        {
            "name": "Test mono re10k",
            "type": "debugpy",
            "request": "launch",
            "module": "src.main",
            // "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "CUDA_VISIBLE_DEVICES": "5",
                "PYTHONPATH": "/data0/xxy/code/Active-FFGS-streaming/src/third_party/video_depth_anything:${env:PYTHONPATH}"
                // "MASTER_ADDR": "localhost",
                // "MASTER_PORT": "12345",
            },
            "args": [
                "+experiment=re10k",
                "dataset.roots=[/data0/xxy/data/re10k]",
                "data_loader.train.batch_size=2",
                "wandb.mode=disabled",
                "mode=test",
                "model/encoder=mono_model",
                "dataset/view_sampler=evaluation",
                "dataset.view_sampler.index_path=/data0/xxy/code/MonoSplat/assets/evaluation_index_re10k_nctx2.json",
                "dataset.view_sampler.num_context_views=2",
                "dataset.roots=[/data0/xxy/data/re10k]",
                "dataset.image_shape=[256,256]",
                "checkpointing.pretrained_model=pretrained_weights/epoch_9-step_300000.ckpt",
                "checkpointing.no_strict_load=false",
                "test.compute_scores=true",
                "data_loader.test.num_workers=0",
                "data_loader.test.persistent_workers=false",
                "data_loader.test.batch_size=1",
                "dataset.test_len=10",
                "checkpointing.no_strict_load=true"
            ]
        },
    ],
}